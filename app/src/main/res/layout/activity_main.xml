<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/titlebar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintBottom_toTopOf="@id/parameters_scroll">

        <TextView
            android:padding="0dp"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="27sp"
            android:text="@string/app_name"/>

        <Button
            android:id="@+id/start_game_button"
            android:padding="0dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="27sp"
            android:text="@string/begin_game"/>
    </LinearLayout>


    <androidx.core.widget.NestedScrollView
        android:id="@+id/parameters_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/titlebar_layout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <GridLayout
            android:id="@+id/parameters_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="4">

            <TextView
                android:layout_columnWeight="1"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:textSize="27sp"
                android:gravity="start|center"
                android:text="@string/count_rows"/>

            <com.shawnlin.numberpicker.NumberPicker
                android:id="@+id/count_rows"
                android:layout_width="wrap_content"
                android:layout_height="64dp"
                android:textSize="27sp"
                app:np_orientation="horizontal"
                app:np_textColor="@color/picker_text_color"
                app:np_selectedTextColor="@color/picker_selected_text_color"
                app:np_dividerColor="@color/picker_divider_color"
                app:np_min="1"
                app:np_max="100"
                app:np_value="10"
                app:np_width="200dp"
                app:np_textSize="15sp"
                app:np_scrollerEnabled="true"
                app:np_selectedTextSize="20sp"/>

            <TextView
                android:layout_columnWeight="1"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:textSize="27sp"
                android:gravity="start|center"
                android:text="@string/count_columns"/>

            <com.shawnlin.numberpicker.NumberPicker
                android:id="@+id/count_columns"
                android:layout_width="wrap_content"
                android:layout_height="64dp"
                android:textSize="27sp"
                app:np_orientation="horizontal"
                app:np_textColor="@color/picker_text_color"
                app:np_selectedTextColor="@color/picker_selected_text_color"
                app:np_dividerColor="@color/picker_divider_color"
                app:np_min="1"
                app:np_max="100"
                app:np_value="10"
                app:np_width="200dp"
                app:np_textSize="15sp"
                app:np_scrollerEnabled="true"
                app:np_selectedTextSize="20sp"/>

            <TextView
                android:layout_columnWeight="1"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:textSize="27sp"
                android:gravity="start|center"
                android:text="@string/count_mins"/>

            <com.shawnlin.numberpicker.NumberPicker
                android:id="@+id/count_mins"
                android:layout_width="wrap_content"
                android:layout_height="64dp"
                android:textSize="27sp"
                app:np_orientation="horizontal"
                app:np_textColor="@color/picker_text_color"
                app:np_selectedTextColor="@color/picker_selected_text_color"
                app:np_dividerColor="@color/picker_divider_color"
                app:np_min="0"
                app:np_max="10000"
                app:np_value="10"
                app:np_width="200dp"
                app:np_textSize="15sp"
                app:np_scrollerEnabled="true"
                app:np_selectedTextSize="20sp"/>

            <TextView
                android:layout_columnWeight="1"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:textSize="27sp"
                android:gravity="start|center"
                android:text="@string/show_seconds"/>

            <com.shawnlin.numberpicker.NumberPicker
                android:id="@+id/show_seconds"
                android:layout_width="wrap_content"
                android:layout_height="64dp"
                android:textSize="27sp"
                app:np_orientation="horizontal"
                app:np_textColor="@color/picker_text_color"
                app:np_selectedTextColor="@color/picker_selected_text_color"
                app:np_dividerColor="@color/picker_divider_color"
                app:np_min="0"
                app:np_max="1000"
                app:np_value="0"
                app:np_width="200dp"
                app:np_textSize="15sp"
                app:np_scrollerEnabled="true"
                app:np_selectedTextSize="20sp"/>

        </GridLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>